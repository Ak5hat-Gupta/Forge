"use client";
import { useEffect, useState } from "react";

const API = process.env.NEXT_PUBLIC_API_URL || "http://localhost:8000";

interface {{ class_name }} {
  id: number;
{%- for col in columns %}
  {%- if col.inferred_type == "integer" %}
  {{ col.slug }}: number{% if col.nullable %} | null{% endif %};
  {%- elif col.inferred_type == "float" or col.inferred_type == "currency" %}
  {{ col.slug }}: number{% if col.nullable %} | null{% endif %};
  {%- elif col.inferred_type == "boolean" %}
  {{ col.slug }}: boolean{% if col.nullable %} | null{% endif %};
  {%- else %}
  {{ col.slug }}: string{% if col.nullable %} | null{% endif %};
  {%- endif %}
{%- endfor %}
  created_at: string;
}

const COLUMNS = [
{%- for col in columns %}
  { key: "{{ col.slug }}", label: "{{ col.name }}", type: "{{ col.inferred_type }}" },
{%- endfor %}
];

export default function Home() {
  const [items, setItems] = useState<{{ class_name }}[]>([]);
  const [loading, setLoading] = useState(true);
  const [showForm, setShowForm] = useState(false);
  const [form, setForm] = useState<Record<string, unknown>>({});

  const load = async () => {
    setLoading(true);
    const r = await fetch(`${API}/api/{{ resource }}`);
    setItems(await r.json());
    setLoading(false);
  };

  useEffect(() => { load(); }, []);

  const create = async (e: React.FormEvent) => {
    e.preventDefault();
    await fetch(`${API}/api/{{ resource }}`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(form),
    });
    setForm({});
    setShowForm(false);
    load();
  };

  const del = async (id: number) => {
    if (!confirm("Delete?")) return;
    await fetch(`${API}/api/{{ resource }}/${id}`, { method: "DELETE" });
    load();
  };

  return (
    <main className="mx-auto max-w-6xl p-6 lg:p-10">
      <header className="mb-8 flex items-center justify-between">
        <div>
          <h1 className="text-2xl font-bold">{{ app_name }}</h1>
          <p className="text-sm text-muted">{items.length} rows</p>
        </div>
        <button onClick={() => setShowForm(!showForm)} className="btn-primary">
          {showForm ? "Cancel" : "+ Add"}
        </button>
      </header>

      {showForm && (
        <form onSubmit={create} className="mb-8 grid gap-3 rounded-xl border border-line bg-surface p-5 sm:grid-cols-2">
          {COLUMNS.map((c) => (
            <div key={c.key}>
              <label className="lbl">{c.label}</label>
              {c.type === "boolean" ? (
                <input type="checkbox" onChange={(e) => setForm({ ...form, [c.key]: e.target.checked })} className="h-4 w-4 accent-brand" />
              ) : (
                <input
                  type={c.type === "integer" || c.type === "float" || c.type === "currency" ? "number" : c.type === "email" ? "email" : "text"}
                  step={c.type === "float" || c.type === "currency" ? "0.01" : undefined}
                  onChange={(e) => setForm({ ...form, [c.key]: c.type === "integer" ? parseInt(e.target.value) : c.type === "float" || c.type === "currency" ? parseFloat(e.target.value) : e.target.value })}
                  className="field"
                />
              )}
            </div>
          ))}
          <div className="sm:col-span-2 flex justify-end">
            <button type="submit" className="btn-primary">Create</button>
          </div>
        </form>
      )}

      {loading ? (
        <p className="text-muted">Loading...</p>
      ) : (
        <div className="overflow-x-auto rounded-xl border border-line">
          <table className="w-full text-sm">
            <thead className="bg-surface">
              <tr>
                {COLUMNS.map((c) => (
                  <th key={c.key} className="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-muted">{c.label}</th>
                ))}
                <th className="px-4 py-3"></th>
              </tr>
            </thead>
            <tbody>
              {items.map((item) => (
                <tr key={item.id} className="border-t border-line">
                  {COLUMNS.map((c) => (
                    <td key={c.key} className="px-4 py-3">{String((item as Record<string, unknown>)[c.key] ?? "—")}</td>
                  ))}
                  <td className="px-4 py-3 text-right">
                    <button onClick={() => del(item.id)} className="text-xs text-red-400 hover:underline cursor-pointer">Delete</button>
                  </td>
                </tr>
              ))}
              {items.length === 0 && (
                <tr><td colSpan={COLUMNS.length + 1} className="px-4 py-12 text-center text-muted">No rows yet</td></tr>
              )}
            </tbody>
          </table>
        </div>
      )}
    </main>
  );
}
